{
  "manifest_version": 3,
  "name": "greenington",
  "version": "0.1.0",
  "description": "The Whitelist. A browser extension that hides everything except whitelisted channels. Inspired by the AI slop epidemic. YouTube first, more platforms coming.",
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["intercept.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://www.youtube.com/*"],
      "css": ["style.css"],
      "js": ["index.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["whitelist.txt"],
      "matches": ["https://www.youtube.com/*"]
    }
  ]
}
